# Frontend environments:
# staging/tests -> https://staging.validaenota.com.br
# main/production -> https://app.validaenota.com.br
#
# Backend environments:
# staging/tests -> https://staging.api.validaenota.com.br
# main/production -> https://api.validaenota.com.br

VITE_APP_ENV=staging
VITE_USE_MOCK_API=false
VITE_API_BASE_URL=https://staging.api.validaenota.com.br

# Production example:
# VITE_APP_ENV=main
# VITE_USE_MOCK_API=false
# VITE_API_BASE_URL=https://api.validaenota.com.br
